#!/usr/bin/env python3
"""Codex Stop hook: steer back into Playbook after no-task code edits."""

from __future__ import annotations

import json
import os
import sys
from pathlib import Path


def _bootstrap_imports() -> None:
    script_dir = Path(__file__).resolve().parent
    candidates = [script_dir / "lib", script_dir.parent / "src"]
    for candidate in candidates:
        if candidate.exists():
            sys.path.insert(0, str(candidate))
            return


def _find_project_root() -> Path:
    env_root = os.environ.get("PLAYBOOK_PROJECT_ROOT")
    if env_root:
        return Path(env_root)
    cwd = Path.cwd()
    for path in [cwd] + list(cwd.parents):
        if (path / ".agent" / "tasks").exists():
            return path
    return cwd


def main() -> int:
    _bootstrap_imports()
    from provider.codex_hooks import stop_decision_for_no_task_code_changes

    payload = json.load(sys.stdin)
    project_root = _find_project_root()
    from provider.codex_hooks import resolve_session_id
    session_id = resolve_session_id()
    turn_id = payload.get("turn_id")

    decision = stop_decision_for_no_task_code_changes(
        project_root=project_root,
        session_id=session_id,
        turn_id=turn_id,
    )
    sys.stdout.write(json.dumps(decision))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
