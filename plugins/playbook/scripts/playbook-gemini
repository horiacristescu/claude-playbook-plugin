#!/bin/bash
# bin/playbook-gemini — launch Gemini CLI with a unique per-session Playbook session ID.
#
# Usage: playbook-gemini [gemini-args...]
#
# Generates PLAYBOOK_SESSION_ID, provisions the session directory, then execs
# gemini so the agent inherits the env.  GEMINI.md in the project root carries
# workflow instructions (advisory — Gemini hook model not yet verified).
#
# Canonical user-facing entry point.  See src/provider/adapters/gemini.py
# launch_interactive() for the programmatic equivalent (assumes env pre-set).

set -e

# Find project root (directory containing .agent/tasks/)
find_project_root() {
    local dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -d "$dir/.agent/tasks" ]; then
            echo "$dir"
            return 0
        fi
        dir="$(dirname "$dir")"
    done
    echo ""
}

PROJECT_ROOT="$(find_project_root)"

# PID-based session ID: pid-$$ (this wrapper's PID = parent of gemini process)
SESSION_ID="pid-$$"
export PLAYBOOK_SESSION_ID="$SESSION_ID"
export PLAYBOOK_PROJECT_ROOT="$PROJECT_ROOT"

# Provision session directory so state files have a home
if [ -n "$PROJECT_ROOT" ]; then
    mkdir -p "$PROJECT_ROOT/.agent/sessions/$SESSION_ID"
fi

exec gemini "$@"
