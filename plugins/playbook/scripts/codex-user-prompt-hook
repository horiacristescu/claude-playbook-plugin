#!/usr/bin/env python3
"""Capture a per-turn dirty-code baseline for Codex Stop enforcement."""

from __future__ import annotations

import json
import os
import sys
from pathlib import Path


def _bootstrap_imports() -> None:
    script_dir = Path(__file__).resolve().parent
    candidates = [script_dir / "lib", script_dir.parent / "src"]
    for candidate in candidates:
        if candidate.exists():
            sys.path.insert(0, str(candidate))
            return


def _find_project_root() -> Path:
    env_root = os.environ.get("PLAYBOOK_PROJECT_ROOT")
    if env_root:
        return Path(env_root)
    cwd = Path.cwd()
    for path in [cwd] + list(cwd.parents):
        if (path / ".agent" / "tasks").exists():
            return path
    return cwd


def main() -> int:
    _bootstrap_imports()
    from provider.codex_hooks import save_turn_baseline

    payload = json.load(sys.stdin)
    turn_id = payload.get("turn_id")

    project_root = _find_project_root()
    session_id = os.environ.get("PLAYBOOK_SESSION_ID", "") or "default"
    save_turn_baseline(project_root, session_id, turn_id)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
