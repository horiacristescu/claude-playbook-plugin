#!/usr/bin/env python3


"""Log Codex prompts and capture a per-turn dirty-code baseline."""

from __future__ import annotations

# Skip when invoked from the monitor's own claude session (see launch-monitor).
# Log to stderr so the hook's firing is still visible; only gate-enforcement skipped.
import os as _os
import sys as _sys
if _os.environ.get("PLAYBOOK_ROLE") == "monitor":
    print(f"[{__file__.rsplit('/', 1)[-1]}] skip (PLAYBOOK_ROLE=monitor)", file=_sys.stderr)
    _sys.exit(0)

import json
import os
import sys
from pathlib import Path


def _bootstrap_imports() -> None:
    script_dir = Path(__file__).resolve().parent
    candidates = [script_dir / "lib", script_dir.parent / "src"]
    for candidate in candidates:
        if candidate.exists():
            sys.path.insert(0, str(candidate))
            return


def _find_project_root() -> Path:
    env_root = os.environ.get("PLAYBOOK_PROJECT_ROOT")
    if env_root:
        return Path(env_root)
    cwd = Path.cwd()
    for path in [cwd] + list(cwd.parents):
        if (path / ".agent" / "tasks").exists():
            return path
    return cwd


def main() -> int:
    _bootstrap_imports()
    from provider.codex_hooks import append_prompt_to_chat_log, save_turn_baseline

    payload = json.load(sys.stdin)
    turn_id = payload.get("turn_id")
    prompt = payload.get("prompt")

    project_root = _find_project_root()
    from provider.codex_hooks import resolve_session_id
    session_id = resolve_session_id()
    append_prompt_to_chat_log(project_root, session_id, prompt)
    save_turn_baseline(project_root, session_id, turn_id)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
